{
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server/index.js" },
    { "src": "/admin", "dest": "server/index.js" },
    { "src": "/uploads/(.*)", "dest": "server/index.js" },
    { "src": "/assets/(.*)", "dest": "dist/assets/$1" },
    { "src": "/(.*)", "dest": "dist/index.html" }
  ]
}
